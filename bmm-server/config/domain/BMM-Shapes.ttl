@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix oslc:    <http://open-services.net/ns/core#> .
@prefix oslc_am: <http://open-services.net/ns/am#> .
@prefix jazz_am: <http://jazz.net/ns/dm/linktypes#> .
@prefix bmm:     <http://www.omg.org/spec/BMM#> .

# ================================================================
# OSLC Resource Shapes for the OMG Business Motivation Model (BMM)
#
# bmm:MotivationalElement rdfs:subClassOf oslc_am:Resource, so all
# BMM resource shapes inherit the standard OSLC Core and AM properties.
#
# OSLC ResourceShapes do NOT support inheritance — every concrete
# shape must manually enumerate all properties it allows, including
# those inherited through the class hierarchy. Shared property
# definitions are named nodes (below) and referenced by each shape's
# oslc:property list; this gives the appearance of inheritance while
# remaining OSLC-conformant.
#
# Forward link properties carry oslc:inversePropertyDefinition and
# oslc:inverseLabel metadata. The inverse URIs are identifiers only;
# they are never asserted as triples. oslc-browser uses the inverse
# URI + label to render incoming links (discovered via LDM) as if
# they were outgoing, so link ownership is transparent to the user.
# ================================================================


# ================================================================
# SHARED PROPERTY DEFINITIONS — Inherited from oslc_am:Resource
# ================================================================

<#p-title>
  a oslc:Property ;
  oslc:name "title" ;
  oslc:propertyDefinition dcterms:title ;
  dcterms:description "Title of the resource." ;
  oslc:occurs oslc:Exactly-one ;
  oslc:valueType xsd:string .

<#p-description>
  a oslc:Property ;
  oslc:name "description" ;
  oslc:propertyDefinition dcterms:description ;
  dcterms:description "Descriptive text about the resource." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:string .

<#p-identifier>
  a oslc:Property ;
  oslc:name "identifier" ;
  oslc:propertyDefinition dcterms:identifier ;
  dcterms:description "Unique identifier of the resource." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:string ;
  oslc:readOnly true .

<#p-creator>
  a oslc:Property ;
  oslc:name "creator" ;
  oslc:propertyDefinition dcterms:creator ;
  dcterms:description "Creator of the resource." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType oslc:AnyResource ;
  oslc:representation oslc:Either .

<#p-modified>
  a oslc:Property ;
  oslc:name "modified" ;
  oslc:propertyDefinition dcterms:modified ;
  dcterms:description "Date the resource was last modified." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:dateTime ;
  oslc:readOnly true .

<#p-type>
  a oslc:Property ;
  oslc:name "type" ;
  oslc:propertyDefinition rdf:type ;
  dcterms:description "RDF type of the resource." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType oslc:Resource ;
  oslc:representation oslc:Reference .

<#p-instanceShape>
  a oslc:Property ;
  oslc:name "instanceShape" ;
  oslc:propertyDefinition oslc:instanceShape ;
  dcterms:description "Resource shape that describes this resource." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType oslc:Resource ;
  oslc:representation oslc:Reference ;
  oslc:readOnly true .

<#p-contributor>
  a oslc:Property ;
  oslc:name "contributor" ;
  oslc:propertyDefinition dcterms:contributor ;
  dcterms:description "Contributor to the resource." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType oslc:AnyResource ;
  oslc:representation oslc:Either .

<#p-created>
  a oslc:Property ;
  oslc:name "created" ;
  oslc:propertyDefinition dcterms:created ;
  dcterms:description "Date the resource was created." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:dateTime ;
  oslc:readOnly true .

<#p-subject>
  a oslc:Property ;
  oslc:name "subject" ;
  oslc:propertyDefinition dcterms:subject ;
  dcterms:description "Tag or keyword for the resource." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType xsd:string .

<#p-serviceProvider>
  a oslc:Property ;
  oslc:name "serviceProvider" ;
  oslc:propertyDefinition oslc:serviceProvider ;
  dcterms:description "OSLC service provider for this resource." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType oslc:Resource ;
  oslc:representation oslc:Reference ;
  oslc:readOnly true .

<#p-shortTitle>
  a oslc:Property ;
  oslc:name "shortTitle" ;
  oslc:propertyDefinition oslc:shortTitle ;
  dcterms:description "Shorter form of the title." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:string .

<#p-dctype>
  a oslc:Property ;
  oslc:name "dctype" ;
  oslc:propertyDefinition dcterms:type ;
  dcterms:description "A short string representation for the type, e.g. \"Goal\"." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType xsd:string .

<#p-source>
  a oslc:Property ;
  oslc:name "source" ;
  oslc:propertyDefinition dcterms:source ;
  dcterms:description "A resource URI that can be fetched to obtain the original non-OSLC-formatted resource from which this BMM resource was derived." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType oslc:Resource ;
  oslc:representation oslc:Reference .

# ================================================================
# SHARED PROPERTY DEFINITIONS — AM common link types
# (inherited from oslc_am:Resource)
# ================================================================

<#p-derives>
  a oslc:Property ;
  oslc:name "derives" ;
