  oslc:representation oslc:Reference ;
  oslc:inversePropertyDefinition bmm:realizedBy ;
  oslc:inverseLabel "Realized By" .

<#p-governedByBusinessRule>
  a oslc:Property ;
  oslc:name "governedByBusinessRule" ;
  oslc:propertyDefinition bmm:governedByBusinessRule ;
  dcterms:description "BusinessRules that govern this BusinessProcess." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType oslc:Resource ;
  oslc:representation oslc:Reference ;
  oslc:inversePropertyDefinition bmm:governsProcessVia ;
  oslc:inverseLabel "Governs Process" .


