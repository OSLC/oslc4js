  dcterms:description "A resource from which this resource derives or is significantly influenced by. For example, a BMM Goal may derive from a requirement in a Requirements Management tool." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType oslc:Resource ;
  oslc:representation oslc:Reference ;
  oslc:inversePropertyDefinition jazz_am:derivedBy ;
  oslc:inverseLabel "Derived By" .

