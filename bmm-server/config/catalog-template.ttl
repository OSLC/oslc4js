@prefix : <#>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix core: <http://open-services.net/ns/core#>.
@prefix BMM: <http://www.omg.org/spec/BMM#>.
@prefix spec: <http://www.omg.org/spec/>.

<catalog>
    dct:description "Root ServiceProviderCatalog for bmm-server";
    dct:publisher
    [ a core:Publisher; dct:identifier "bmm-server"; dct:title "Bmm Server" ];
    dct:title "Bmm Server Service Provider Catalog".
<sp> a core:ServiceProvider; core:service <sp/service>.

<sp/service>
    a core:Service;
    core:creationDialog
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Assessment";
                core:resourceShape <domain/BMM-Shapes#AssessmentShape>;
                core:resourceType BMM:Assessment;
                dct:title "New Assessment"
            ],
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Asset";
                core:resourceShape <domain/BMM-Shapes#AssetShape>;
                core:resourceType BMM:Asset;
                dct:title "New Asset"
            ],
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Business Policy";
                core:resourceShape <domain/BMM-Shapes#BusinessPolicyShape>;
                core:resourceType BMM:BusinessPolicy;
                dct:title "New Business Policy"
            ],
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Business Process";
                core:resourceShape <domain/BMM-Shapes#BusinessProcessShape>;
                core:resourceType BMM:BusinessProcess;
                dct:title "New Business Process"
            ],
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Business Rule";
                core:resourceShape <domain/BMM-Shapes#BusinessRuleShape>;
                core:resourceType BMM:BusinessRule;
                dct:title "New Business Rule"
            ],
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Goal";
                core:resourceShape <domain/BMM-Shapes#GoalShape>;
                core:resourceType BMM:Goal;
                dct:title "New Goal"
            ],
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Influencer";
                core:resourceShape <domain/BMM-Shapes#InfluencerShape>;
                core:resourceType BMM:Influencer;
                dct:title "New Influencer"
            ],
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Mission";
                core:resourceShape <domain/BMM-Shapes#MissionShape>;
                core:resourceType BMM:Mission;
                dct:title "New Mission"
            ],
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Objective";
                core:resourceShape <domain/BMM-Shapes#ObjectiveShape>;
                core:resourceType BMM:Objective;
                dct:title "New Objective"
            ],
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Organization Unit";
                core:resourceShape <domain/BMM-Shapes#OrganizationUnitShape>;
                core:resourceType BMM:OrganizationUnit;
                dct:title "New Organization Unit"
            ],
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Potential Impact";
                core:resourceShape <domain/BMM-Shapes#PotentialImpactShape>;
                core:resourceType BMM:PotentialImpact;
                dct:title "New Potential Impact"
            ],
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Strategy";
                core:resourceShape <domain/BMM-Shapes#StrategyShape>;
                core:resourceType BMM:Strategy;
                dct:title "New Strategy"
            ],
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Tactic";
                core:resourceShape <domain/BMM-Shapes#TacticShape>;
                core:resourceType BMM:Tactic;
                dct:title "New Tactic"
            ],
            [
                a core:Dialog;
                core:hintHeight "505px";
                core:hintWidth "680px";
                core:label "Vision";
                core:resourceShape <domain/BMM-Shapes#VisionShape>;
                core:resourceType BMM:Vision;
                dct:title "New Vision"
            ];
    core:creationFactory
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#AssessmentShape>;
                core:resourceType BMM:Assessment;
                dct:title "Assessments"
            ],
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#AssetShape>;
                core:resourceType BMM:Asset;
                dct:title "Assets"
            ],
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#BusinessPolicyShape>;
                core:resourceType BMM:BusinessPolicy;
                dct:title "Business Policies"
            ],
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#BusinessProcessShape>;
                core:resourceType BMM:BusinessProcess;
                dct:title "Business Processes"
            ],
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#BusinessRuleShape>;
                core:resourceType BMM:BusinessRule;
                dct:title "Business Rules"
            ],
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#GoalShape>;
                core:resourceType BMM:Goal;
                dct:title "Goals"
            ],
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#InfluencerShape>;
                core:resourceType BMM:Influencer;
                dct:title "Influencers"
            ],
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#MissionShape>;
                core:resourceType BMM:Mission;
                dct:title "Missions"
            ],
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#ObjectiveShape>;
                core:resourceType BMM:Objective;
                dct:title "Objectives"
            ],
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#OrganizationUnitShape>;
                core:resourceType BMM:OrganizationUnit;
                dct:title "Organization Units"
            ],
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#PotentialImpactShape>;
                core:resourceType BMM:PotentialImpact;
                dct:title "Potential Impacts"
            ],
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#StrategyShape>;
                core:resourceType BMM:Strategy;
                dct:title "Strategies"
            ],
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#TacticShape>;
                core:resourceType BMM:Tactic;
                dct:title "Tactics"
            ],
            [
                a core:CreationFactory;
                core:resourceShape <domain/BMM-Shapes#VisionShape>;
                core:resourceType BMM:Vision;
                dct:title "Visions"
            ];
    core:domain spec:BMM;
    # Single QueryCapability — the server has one /query endpoint that
    # accepts any OSLC query filter. Clients disambiguate by resource
    # type (or any other property) via oslc.where, e.g.
    #   oslc.where=rdf:type=<http://www.omg.org/spec/BMM#Goal>
    core:queryCapability
            [
                a core:QueryCapability;
                dct:title "Query BMM Resources"
            ].
