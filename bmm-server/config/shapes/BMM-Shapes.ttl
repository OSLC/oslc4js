# ================================================================
# RESOURCE SHAPE DEFINITIONS
# ================================================================

# ============================================================
# Vision
# ============================================================

<#VisionShape>
  a oslc:ResourceShape ;
  dcterms:title "Vision" ;
  oslc:describes bmm:Vision ;
  oslc:property <#p-title>, <#p-description>, <#p-identifier>,
    <#p-creator>, <#p-contributor>, <#p-created>, <#p-modified>,
    <#p-subject>, <#p-type>, <#p-instanceShape>,
    <#p-serviceProvider>, <#p-shortTitle>,
    <#p-enabledByCourseOfAction>,
    <#p-amplifiedByMission>, <#p-madeOperativeByGoal> .

# ============================================================
# Goal
# ============================================================

<#GoalShape>
  a oslc:ResourceShape ;
  dcterms:title "Goal" ;
  oslc:describes bmm:Goal ;
  oslc:property <#p-title>, <#p-description>, <#p-identifier>,
    <#p-creator>, <#p-contributor>, <#p-created>, <#p-modified>,
    <#p-subject>, <#p-type>, <#p-instanceShape>,
    <#p-serviceProvider>, <#p-shortTitle>,
    <#p-enabledByCourseOfAction>,
    <#p-amplifiesVision>, <#p-quantifiedByObjective>, <#p-includesGoal> .

# ============================================================
# Objective
# ============================================================

<#ObjectiveShape>
  a oslc:ResourceShape ;
  dcterms:title "Objective" ;
  oslc:describes bmm:Objective ;
  oslc:property <#p-title>, <#p-description>, <#p-identifier>,
    <#p-creator>, <#p-contributor>, <#p-created>, <#p-modified>,
    <#p-subject>, <#p-type>, <#p-instanceShape>,
    <#p-serviceProvider>, <#p-shortTitle>,
    <#p-enabledByCourseOfAction>,
