<#p-subOrganizationUnits>
  a oslc:Property ;
  oslc:name "subOrganizationUnits" ;
  oslc:propertyDefinition bmm:subOrganizationUnits ;
  dcterms:description "Child OrganizationUnits." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType oslc:Resource ;
  oslc:representation oslc:Reference .

