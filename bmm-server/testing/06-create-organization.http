###############################################################################
# 06-create-organization.http — OrganizationUnits, BusinessProcesses, Assets
#
# BMM Organization model:
#   OrganizationUnit is responsible for Ends and establishes Means
#   BusinessProcesses are governed by Policies and Rules
#   Assets are resources deployed to support CoursesOfAction
###############################################################################

@baseUrl = http://localhost:3005

### ── Organization Units ──────────────────────────────────────────────

### OrgUnit 1: Executive Leadership
POST {{baseUrl}}/oslc/solartech/resources
Content-Type: text/turtle
Slug: org-executive

@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix bmm:     <http://www.omg.org/spec/BMM#> .

<> a bmm:OrganizationUnit ;
   dcterms:title "Executive Leadership Team" ;
   dcterms:description "CEO, COO, CFO, CTO — responsible for the enterprise Vision, Mission, and overall Strategy." .

### OrgUnit 2: R&D Division
POST {{baseUrl}}/oslc/solartech/resources
Content-Type: text/turtle
Slug: org-research

@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix bmm:     <http://www.omg.org/spec/BMM#> .

<> a bmm:OrganizationUnit ;
   dcterms:title "Research & Development" ;
   dcterms:description "Solar cell research, product development, and prototype testing. Responsible for the Product Innovation strategy and perovskite research tactic." .

### OrgUnit 3: Manufacturing
POST {{baseUrl}}/oslc/solartech/resources
Content-Type: text/turtle
Slug: org-manufacturing

@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix bmm:     <http://www.omg.org/spec/BMM#> .

<> a bmm:OrganizationUnit ;
